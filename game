# LEVEL 5 — CODE BREAKER  (formerly Level 3)
# ─────────────────────────────────────────────
class Level5Screen(BaseScreen):
    def __init__(self, parent, controller):
        super().__init__(parent, controller)

        self.code      = []
        self.time_left = 120
        self.running   = False

        tk.Label(self, text="Level 5: Code Breaker",
                 font=controller.title_font, bg="#1e1e2e", fg="#cba6f7").pack(pady=10)

        rules = ("Rules:\n"
                 "- Crack the 4-digit code to unlock the final door.\n"
                 "- You have 120 seconds.\n"
                 "- Clues per digit: 'Correct' (right digit & place),\n"
                 "  'Misplaced' (right digit, wrong place), 'Wrong' (not in code).")
        tk.Label(self, text=rules, font=controller.normal_font,
                 bg="#1e1e2e", fg="#cdd6f4", justify="left").pack(pady=5)

        self.timer_lbl = tk.Label(self, text="120.0s", font=controller.header_font,
                                  bg="#1e1e2e", fg="#f38ba8")
        self.timer_lbl.pack(pady=5)

        inp_frame = tk.Frame(self, bg="#1e1e2e")
        inp_frame.pack(pady=10)
        self.guess_ent = tk.Entry(inp_frame, font=controller.header_font,
                                  width=10, justify="center")
        self.guess_ent.pack(side="left", padx=10)
        self.guess_btn = tk.Button(inp_frame, text="GUESS", font=controller.header_font,
                                   bg="#cba6f7", fg="#11111b", command=self.check_guess)
        self.guess_btn.pack(side="left")

        self.logs = tk.Text(self, width=55, height=10, font=controller.normal_font,
                            bg="#313244", fg="#cdd6f4", state="disabled")
        self.logs.pack(pady=10)

        self.start_btn = tk.Button(self, text="START TIMER", font=controller.header_font,
                                   bg="#a6e3a1", fg="#11111b", command=self.start_game)
        self.start_btn.pack(pady=10)

    def on_show(self):
        self.code      = [str(random.randint(0, 9)) for _ in range(4)]
        self.time_left = 120
        self.running   = False
        self.timer_lbl.config(text="120.0s", fg="#f38ba8")
        self.logs.config(state="normal")
        self.logs.delete(1.0, tk.END)
        self.logs.config(state="disabled")
        self.log_msg("System ready. Press START TIMER when ready.")
        self.guess_btn.config(state="disabled")
        self.start_btn.config(state="normal")

    def start_game(self):
        self.running = True
        self.start_btn.config(state="disabled")
        self.guess_btn.config(state="normal")
        self.code = [str(random.randint(0, 9)) for _ in range(4)]
        self.logs.config(state="normal")
        self.logs.delete(1.0, tk.END)
        self.logs.config(state="disabled")
        self.log_msg("Started! Timer is running...")
        self.start_time = time.time()
        self.update_timer()

    def update_timer(self):
        if not self.running:
            return
        elapsed = time.time() - self.start_time
        rem = 120 - elapsed
        if rem <= 0:
            rem = 0
            self.running = False
            self.timer_lbl.config(text="0.0s", fg="#f38ba8")
            self.guess_btn.config(state="disabled")
            self.log_msg(f"TIME'S UP! The code was {''.join(self.code)}.")
            messagebox.showinfo("Game Over", "You failed to escape. Try again from the start!")
            return
        self.timer_lbl.config(text=f"{rem:.1f}s")
        self.after(100, self.update_timer)

    def log_msg(self, msg):
        self.logs.config(state="normal")
        self.logs.insert(tk.END, msg + "\n")
        self.logs.see(tk.END)
        self.logs.config(state="disabled")

    def check_guess(self):
        if not self.running:
            return
        guess = self.guess_ent.get().strip()
        if len(guess) != 4 or not guess.isdigit():
            messagebox.showerror("Error", "Enter exactly 4 digits.")
            return
        self.guess_ent.delete(0, tk.END)

        # ── Proper Mastermind hint (handles duplicate digits correctly) ──
        code_copy  = list(self.code)
        guess_copy = list(guess)
        clues = [""] * 4

        # First pass: find exact matches
        for i in range(4):
            if guess_copy[i] == code_copy[i]:
                clues[i] = "Correct"
                code_copy[i]  = None
                guess_copy[i] = None

        # Second pass: find misplaced digits
        for i in range(4):
            if guess_copy[i] is None:
                continue
            if guess_copy[i] in code_copy:
                clues[i] = "Misplaced"
                code_copy[code_copy.index(guess_copy[i])] = None
            else:
                clues[i] = "Wrong"

        clue_str = ", ".join(clues)
        self.log_msg(f"Guess: {guess} → {clue_str}")

        if list(guess) == self.code:
            self.running = False
            self.guess_btn.config(state="disabled")
            self.log_msg("🎉 ACCESS GRANTED — You escaped!")
            messagebox.showinfo("🎉 WINNER!", "You cracked the code and ESCAPED the room!\nCongratulations!")


