# --- LOGIC GATES ---
def AND_logic(inputs): return int(all(inputs))
def OR_logic(inputs): return int(any(inputs))
def XOR_logic(inputs): return int(sum(inputs) % 2 != 0)
def NAND_logic(inputs): return 1 - int(all(inputs))
def NOR_logic(inputs): return 1 - int(any(inputs))

class GameApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Escape Room: Complete Game")
        self.geometry("900x750")
        self.configure(bg="#1e1e2e")

        self.title_font  = tkfont.Font(family="Helvetica", size=24, weight="bold")
        self.header_font = tkfont.Font(family="Helvetica", size=16, weight="bold")
        self.normal_font = tkfont.Font(family="Helvetica", size=14)

        self.players = []

        self.container = tk.Frame(self, bg="#1e1e2e")
        self.container.pack(fill="both", expand=True)
        self.container.grid_rowconfigure(0, weight=1)
        self.container.grid_columnconfigure(0, weight=1)

        self.frames = {}
        for F in (MainMenu, Level1Screen, Level2Screen,
                  Level3Screen, Level4Screen, Level5Screen):
            page_name = F.__name__
            frame = F(parent=self.container, controller=self)
            self.frames[page_name] = frame
            frame.grid(row=0, column=0, sticky="nsew")

        self.show_frame("MainMenu")

    def show_frame(self, page_name):
        frame = self.frames[page_name]
        frame.tkraise()
        if hasattr(frame, 'on_show'):
            frame.on_show()


