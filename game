    def on_show(self):
        self.round_data    = random.sample(self.WORD_POOLS, 4)
        self.imposter_idx  = random.randint(0, 3)
        self.current_round = 0
        for j in range(4):
            self.player_clue_labels[j].config(text="—", fg="#6c7086")
        for i in range(4):
            for j in range(4):
                self.clue_labels[i][j].config(text="—", fg="#6c7086")
        self.info_lbl.config(text="Round 1 / 4  —  Type your word guess and hit SUBMIT!")
        self._show_hint()
        self.result_lbl.config(text="")
        self.submit_btn.config(state="normal")
        self.word_entry.config(state="normal")
        self.word_entry.delete(0, tk.END)
        self.vote_btn.config(state="disabled")
        self.next_btn.config(state="disabled")

    def _show_hint(self):
        if self.current_round < 4:
            _, hint, _, _ = self.round_data[self.current_round]
            self.info_lbl.config(
                text=f"Round {self.current_round + 1} / 4  —  Hint: \"{hint}\"")

    def submit_word(self):
        r = self.current_round
        if r >= 4:
            return
        player_word = self.word_entry.get().strip()
        if not player_word:
            messagebox.showerror("Error", "Please type a word guess!")
            return
        self.player_clue_labels[r].config(text=player_word, fg="#ffffff")
        self.word_entry.delete(0, tk.END)
        _, _, crew_clues, imp_clues = self.round_data[r]
        available_crew = list(crew_clues)
        available_imp  = list(imp_clues)
        random.shuffle(available_crew)
        random.shuffle(available_imp)
        for i in range(4):
            if i == self.imposter_idx:
                clue = available_imp.pop() if available_imp else "Hmm..."
            else:
                clue = available_crew.pop() if available_crew else "..."
            self.clue_labels[i][r].config(text=clue, fg=self.NPC_COLORS[i])
        self.current_round += 1
        if self.current_round >= 4:
            self.submit_btn.config(state="disabled")
            self.word_entry.config(state="disabled")
            self.vote_btn.config(state="normal")
            self.info_lbl.config(text="All 4 rounds done! 🗳 Vote for the Imposter now!")
        else:
            self._show_hint()

    def open_vote(self):
        vote_win = tk.Toplevel(self, bg="#1e1e2e")
        vote_win.title("Vote: Who is the Imposter?")
        vote_win.geometry("420x350")
        vote_win.resizable(False, False)
        vote_win.grab_set()
        tk.Label(vote_win, text="Who is the Imposter?",
                 font=self.controller.header_font, bg="#1e1e2e", fg="#f9e2af").pack(pady=15)
        tk.Label(vote_win,
                 text="Study the clue table carefully.\nOne player's clues don't match the hints!",
                 font=self.controller.normal_font, bg="#1e1e2e", fg="#bac2de",
                 wraplength=380, justify="center").pack(pady=(0, 15))
        for i in range(4):
            tk.Button(vote_win, text=f"  EJECT {self.NPC_NAMES[i]}  ",
                      font=self.controller.normal_font,
                      bg=self.NPC_COLORS[i], fg="#11111b", width=22,
                      command=lambda idx=i, w=vote_win: self.cast_vote(idx, w)).pack(pady=5)

    def cast_vote(self, chosen_idx, vote_window):
        vote_window.destroy()
        self.vote_btn.config(state="disabled")
        imposter_name = self.NPC_NAMES[self.imposter_idx]
        reveal = "Secret words were: " + ", ".join(
            f'R{i+1}="{self.round_data[i][0]}"' for i in range(4))
        if chosen_idx == self.imposter_idx:
            self.result_lbl.config(
                text=f"🎉 Correct! {imposter_name} was the Imposter!\n{reveal}",
                fg="#a6e3a1")
            self.next_btn.config(state="normal")
        else:
            chosen_name = self.NPC_NAMES[chosen_idx]
            self.result_lbl.config(
                text=f"❌ Wrong! {chosen_name} was a Crewmate!\n"
                     f"The Imposter was {imposter_name}.\n{reveal}",
                fg="#f38ba8")
            retry_btn = tk.Button(self, text="🔄  RETRY LEVEL 2",
                                  font=self.controller.header_font,
                                  bg="#fab387", fg="#11111b",
                                  command=lambda: self._retry(retry_btn))
            retry_btn.pack(pady=5)

    def _retry(self, retry_btn):
        retry_btn.destroy()
        self.on_show()


# ─────────────────────────────────────────────
# LEVEL 3 — LOGIC GATE PUZZLE  ✦ NEW
# ─────────────────────────────────────────────
class Level3Screen(BaseScreen):
    """
    Player is shown a logic gate (AND / OR / XOR / NAND / NOR) and a target output (0 or 1).
    They must flip input toggles until the gate produces that output.
    3 puzzles per run, randomly chosen.
    """

    GATES = [
        ("AND",  AND_logic,  "#89b4fa"),
        ("OR",   OR_logic,   "#a6e3a1"),
        ("XOR",  XOR_logic,  "#f9e2af"),
        ("NAND", NAND_logic, "#fab387"),
        ("NOR",  NOR_logic,  "#f38ba8"),
    ]

    # Gate truth-table descriptions shown as a hint
    GATE_HINTS = {
        "AND":  "Output is 1 only when ALL inputs are 1.",
        "OR":   "Output is 1 when AT LEAST ONE input is 1.",
        "XOR":  "Output is 1 when an ODD number of inputs are 1.",
        "NAND": "Output is 0 only when ALL inputs are 1 (NOT AND).",
        "NOR":  "Output is 0 when ANY input is 1 (NOT OR).",
    }

    def __init__(self, parent, controller):
        super().__init__(parent, controller)

        tk.Label(self, text="Level 3: Logic Gate Puzzle",
                 font=controller.title_font, bg="#1e1e2e", fg="#89b4fa").pack(pady=(15, 5))

        rules = ("Rules:\n"
                 "• Each puzzle shows a logic gate and a TARGET output (0 or 1).\n"
                 "• Toggle the input switches to make the gate produce the target.\n"
                 "• Solve 3 puzzles in a row to proceed!")
        tk.Label(self, text=rules, font=controller.normal_font,
                 bg="#1e1e2e", fg="#cdd6f4", justify="left").pack(pady=5)

        # Progress label
        self.progress_lbl = tk.Label(self, text="", font=controller.header_font,
                                     bg="#1e1e2e", fg="#fab387")
        self.progress_lbl.pack(pady=5)

        # Gate display card
        card = tk.Frame(self, bg="#313244", bd=2, relief="groove")
        card.pack(pady=10, padx=60, fill="x")

        # Gate name + hint
        self.gate_lbl = tk.Label(card, text="", font=controller.title_font,
                                 bg="#313244", fg="#ffffff")
        self.gate_lbl.pack(pady=(15, 2))

        self.hint_lbl = tk.Label(card, text="", font=controller.normal_font,
                                 bg="#313244", fg="#a6adc8", wraplength=600)
        self.hint_lbl.pack(pady=(0, 10))

        # Target output
        target_frame = tk.Frame(card, bg="#313244")
        target_frame.pack(pady=5)
        tk.Label(target_frame, text="Target output:", font=controller.header_font,
                 bg="#313244", fg="#cdd6f4").pack(side="left", padx=10)
        self.target_lbl = tk.Label(target_frame, text="", font=controller.title_font,
                                   bg="#313244", fg="#f9e2af", width=3)
        self.target_lbl.pack(side="left")

        # Input toggles (3 inputs)
        toggles_frame = tk.Frame(card, bg="#313244")
        toggles_frame.pack(pady=10)
        self.input_vars = []
        self.toggle_btns = []
        for i in range(3):
            col = tk.Frame(toggles_frame, bg="#313244")
            col.pack(side="left", padx=20)
            tk.Label(col, text=f"Input {i+1}", font=controller.normal_font,
                     bg="#313244", fg="#cdd6f4").pack()
            var = tk.IntVar(value=0)
            self.input_vars.append(var)
            btn = tk.Button(col, text="0", font=controller.title_font,
                            bg="#45475a", fg="#cdd6f4", width=4,
                            command=lambda v=var, b=None, idx=i: self._toggle(idx))
            btn.pack(pady=5)
            self.toggle_btns.append(btn)

        # Live output display
        out_frame = tk.Frame(card, bg="#313244")
        out_frame.pack(pady=10)
        tk.Label(out_frame, text="Current output:", font=controller.header_font,
                 bg="#313244", fg="#cdd6f4").pack(side="left", padx=10)
        self.output_lbl = tk.Label(out_frame, text="0", font=controller.title_font,
                                   bg="#313244", fg="#f38ba8", width=3)
        self.output_lbl.pack(side="left")

        # Submit button
        self.submit_btn = tk.Button(self, text="✅  LOCK IN ANSWER",
                                    font=controller.header_font,
                                    bg="#a6e3a1", fg="#11111b",
                                    command=self.check_answer)
        self.submit_btn.pack(pady=10)

        self.result_lbl = tk.Label(self, text="", font=controller.header_font,
                                   bg="#1e1e2e", fg="#a6e3a1")
        self.result_lbl.pack(pady=5)

        self.next_btn = tk.Button(self, text="Proceed to Level 4",
                                  font=controller.normal_font, bg="#a6e3a1",
                                  fg="#11111b", state="disabled",
                                  command=lambda: controller.show_frame("Level4Screen"))
        self.next_btn.pack(pady=10)

    def on_show(self):
        self.puzzles_solved = 0
        self.total_puzzles  = 3
        self._load_puzzle()
        self.result_lbl.config(text="")
        self.next_btn.config(state="disabled")

    def _load_puzzle(self):
        # Pick a random gate and generate a solvable puzzle
        gate_name, gate_fn, gate_color = random.choice(self.GATES)
        self.current_gate_fn   = gate_fn
        self.current_gate_name = gate_name

        # Random target output 0 or 1
        self.target_output = random.randint(0, 1)

        # Reset inputs
        for i, var in enumerate(self.input_vars):
            var.set(0)
            self.toggle_btns[i].config(text="0", bg="#45475a", fg="#cdd6f4")

        self.gate_lbl.config(text=f"⬛ {gate_name} Gate", fg=gate_color)
        self.hint_lbl.config(text=self.GATE_HINTS[gate_name])
        self.target_lbl.config(
            text=str(self.target_output),
            fg="#a6e3a1" if self.target_output == 1 else "#f38ba8")
        self.progress_lbl.config(
            text=f"Puzzle {self.puzzles_solved + 1} of {self.total_puzzles}")
        self.submit_btn.config(state="normal")
        self.result_lbl.config(text="")
        self._update_output_display()

    def _toggle(self, idx):
        new_val = 1 - self.input_vars[idx].get()
        self.input_vars[idx].set(new_val)
        if new_val == 1:
            self.toggle_btns[idx].config(text="1", bg="#89b4fa", fg="#11111b")
        else:
            self.toggle_btns[idx].config(text="0", bg="#45475a", fg="#cdd6f4")
        self._update_output_display()

    def _update_output_display(self):
        inputs = [v.get() for v in self.input_vars]
        out = self.current_gate_fn(inputs)
        self.output_lbl.config(
            text=str(out),
            fg="#a6e3a1" if out == 1 else "#f38ba8")

    def check_answer(self):
        inputs = [v.get() for v in self.input_vars]
        out    = self.current_gate_fn(inputs)
        if out == self.target_output:
            self.puzzles_solved += 1
            if self.puzzles_solved >= self.total_puzzles:
                self.submit_btn.config(state="disabled")
                self.result_lbl.config(
                    text="🎉 All puzzles solved! Door unlocked!", fg="#a6e3a1")
                self.next_btn.config(state="normal")
            else:
                self.result_lbl.config(
                    text=f"✅ Correct! ({self.puzzles_solved}/{self.total_puzzles} solved)",
                    fg="#a6e3a1")
                self.after(900, self._load_puzzle)
        else:
            inputs_str = ", ".join(str(v) for v in inputs)
            self.result_lbl.config(
                text=f"❌ Wrong! Inputs [{inputs_str}] → output {out}, not {self.target_output}. Try again!",
                fg="#f38ba8")


