# LEVEL 4 — SIMON SAYS MEMORY GAME  ✦ NEW
# ─────────────────────────────────────────────
class Level4Screen(BaseScreen):
    """
    Simon Says: 4 coloured buttons flash in sequence — player must repeat.
    5 rounds. Sequence grows by 1 each round (1 flash in round 1, 5 in round 5).
    """

    BTN_COLORS = {
        "Red":    {"normal": "#c0404a", "lit": "#ff6b75", "text": "#ffffff"},
        "Blue":   {"normal": "#2255aa", "lit": "#4da6ff", "text": "#ffffff"},
        "Green":  {"normal": "#2a7a3a", "lit": "#4dcc65", "text": "#ffffff"},
        "Yellow": {"normal": "#aa8800", "lit": "#ffd94d", "text": "#11111b"},
    }
    BTN_ORDER = ["Red", "Blue", "Green", "Yellow"]

    FLASH_ON_MS  = 500
    FLASH_OFF_MS = 200
    BETWEEN_MS   = 300

    def __init__(self, parent, controller):
        super().__init__(parent, controller)

        tk.Label(self, text="Level 4: Simon Says",
                 font=controller.title_font, bg="#1e1e2e", fg="#a6e3a1").pack(pady=(15, 5))

        rules = ("Rules:\n"
                 "• Watch the colour sequence carefully — then repeat it!\n"
                 "• The sequence grows by 1 button each round.\n"
                 "• Complete 5 rounds to escape!")
        tk.Label(self, text=rules, font=controller.normal_font,
                 bg="#1e1e2e", fg="#cdd6f4", justify="left").pack(pady=5)

        self.status_lbl = tk.Label(self, text="", font=controller.header_font,
                                   bg="#1e1e2e", fg="#fab387")
        self.status_lbl.pack(pady=8)

        # Coloured buttons (2x2 grid)
        grid_frame = tk.Frame(self, bg="#1e1e2e")
        grid_frame.pack(pady=10)
        self.btns = {}
        positions = [("Red", 0, 0), ("Blue", 0, 1), ("Green", 1, 0), ("Yellow", 1, 1)]
        for name, row, col in positions:
            c = self.BTN_COLORS[name]
            b = tk.Button(grid_frame, text=name, font=controller.header_font,
                          bg=c["normal"], fg=c["text"],
                          width=10, height=4, state="disabled",
                          command=lambda n=name: self._player_press(n))
            b.grid(row=row, column=col, padx=15, pady=15)
            self.btns[name] = b

        self.start_btn = tk.Button(self, text="▶  START GAME",
                                   font=controller.header_font,
                                   bg="#f9e2af", fg="#11111b",
                                   command=self._start)
        self.start_btn.pack(pady=10)

        self.result_lbl = tk.Label(self, text="", font=controller.header_font,
                                   bg="#1e1e2e", fg="#a6e3a1")
        self.result_lbl.pack(pady=5)

        self.next_btn = tk.Button(self, text="Proceed to Level 5",
                                  font=controller.normal_font, bg="#a6e3a1",
                                  fg="#11111b", state="disabled",
                                  command=lambda: controller.show_frame("Level5Screen"))
        self.next_btn.pack(pady=10)

    def on_show(self):
        self.sequence      = []
        self.player_seq    = []
        self.current_round = 0
        self.total_rounds  = 5
        self.accepting     = False
        self.result_lbl.config(text="")
        self.next_btn.config(state="disabled")
        self.start_btn.config(state="normal")
        self.status_lbl.config(text="Press START to begin!")
        for name in self.BTN_ORDER:
            self.btns[name].config(bg=self.BTN_COLORS[name]["normal"], state="disabled")

    def _start(self):
        self.start_btn.config(state="disabled")
        self.sequence      = []
        self.current_round = 0
        self._next_round()

    def _next_round(self):
        self.current_round += 1
        self.sequence.append(random.choice(self.BTN_ORDER))
        self.player_seq = []
        self.accepting  = False
        self.status_lbl.config(
            text=f"Round {self.current_round} / {self.total_rounds}  —  Watch the sequence!")
        self.result_lbl.config(text="")
        for name in self.BTN_ORDER:
            self.btns[name].config(state="disabled")
        self.after(600, lambda: self._play_sequence(0))

    def _play_sequence(self, idx):
        if idx >= len(self.sequence):
            # Done flashing — let player respond
            for name in self.BTN_ORDER:
                self.btns[name].config(state="normal")
            self.accepting = True
            self.status_lbl.config(
                text=f"Round {self.current_round} / {self.total_rounds}  —  Your turn! Repeat the sequence.")
            return
        name = self.sequence[idx]
        self._flash_on(name)
        self.after(self.FLASH_ON_MS, lambda: self._flash_off(name, idx))

    def _flash_on(self, name):
        c = self.BTN_COLORS[name]
        self.btns[name].config(bg=c["lit"])

    def _flash_off(self, name, idx):
        c = self.BTN_COLORS[name]
        self.btns[name].config(bg=c["normal"])
        self.after(self.FLASH_OFF_MS,
                   lambda: self.after(self.BETWEEN_MS,
                                      lambda: self._play_sequence(idx + 1)))

    def _player_press(self, name):
        if not self.accepting:
            return
        # Flash to give feedback
        self._flash_on(name)
        self.after(180, lambda: self.btns[name].config(bg=self.BTN_COLORS[name]["normal"]))

        self.player_seq.append(name)
        idx = len(self.player_seq) - 1

        if self.player_seq[idx] != self.sequence[idx]:
            # Wrong press
            self.accepting = False
            for n in self.BTN_ORDER:
                self.btns[n].config(state="disabled")
            self.result_lbl.config(
                text=f"❌ Wrong! Expected {self.sequence[idx]}, got {name}. Restarting round...",
                fg="#f38ba8")
            self.after(1500, self._retry_round)
            return

        if len(self.player_seq) == len(self.sequence):
            # Completed this round
            self.accepting = False
            for n in self.BTN_ORDER:
                self.btns[n].config(state="disabled")
            if self.current_round >= self.total_rounds:
                self.result_lbl.config(
                    text="🎉 You memorised all 5 sequences! Door unlocked!", fg="#a6e3a1")
                self.next_btn.config(state="normal")
            else:
                self.result_lbl.config(
                    text=f"✅ Round {self.current_round} complete!", fg="#a6e3a1")
                self.after(1000, self._next_round)

    def _retry_round(self):
        # Replay the same sequence
        self.player_seq = []
        self.accepting  = False
        self.status_lbl.config(
            text=f"Round {self.current_round} / {self.total_rounds}  —  Watch again...")
        for name in self.BTN_ORDER:
            self.btns[name].config(state="disabled")
        self.after(400, lambda: self._play_sequence(0))


