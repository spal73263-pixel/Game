# ─────────────────────────────────────────────
# LEVEL 1 — GUESS THE NUMBER
# ─────────────────────────────────────────────
class Level1Screen(BaseScreen):
    def __init__(self, parent, controller):
        super().__init__(parent, controller)

        tk.Label(self, text="Level 1: Guess the Number",
                 font=controller.title_font, bg="#1e1e2e", fg="#f38ba8").pack(pady=20)

        rules = "Rules:\n- The computer chose a number between 1 and 10.\n- Guess correctly to unlock Level 2!"
        tk.Label(self, text=rules, font=controller.normal_font,
                 bg="#1e1e2e", fg="#cdd6f4", justify="left").pack(pady=5)

        self.target_number = random.randint(1, 10)

        ef = tk.Frame(self, bg="#1e1e2e")
        ef.pack(pady=20)
        tk.Label(ef, text="Your Guess (1-10):", bg="#1e1e2e",
                 fg="#cdd6f4", font=controller.normal_font).pack(side="left", padx=10)
        self.guess_ent = tk.Entry(ef, font=controller.normal_font, width=10)
        self.guess_ent.pack(side="left")

        self.btn = tk.Button(self, text="SUBMIT GUESS", font=controller.header_font,
                             bg="#f38ba8", fg="#11111b", command=self.evaluate)
        self.btn.pack(pady=10)

        self.result_lbl = tk.Label(self, text="", font=controller.header_font,
                                   bg="#1e1e2e", fg="#a6e3a1")
        self.result_lbl.pack(pady=10)

        self.next_btn = tk.Button(self, text="Proceed to Level 2",
                                  font=controller.normal_font, bg="#a6e3a1", fg="#11111b",
                                  state="disabled",
                                  command=lambda: controller.show_frame("Level2Screen"))
        self.next_btn.pack(pady=10)

    def on_show(self):
        self.target_number = random.randint(1, 10)
        self.result_lbl.config(text="")
        self.next_btn.config(state="disabled")
        self.btn.config(state="normal")
        self.guess_ent.delete(0, tk.END)

    def evaluate(self):
        try:
            val = int(self.guess_ent.get().strip())
        except ValueError:
            messagebox.showerror("Error", "Please enter a valid number.")
            return

        if val == self.target_number:
            self.result_lbl.config(
                text=f"✅ Correct! The number was {self.target_number}.", fg="#a6e3a1")
            self.btn.config(state="disabled")
            self.next_btn.config(state="normal")
            self.controller.players = ["Player 1", "Player 2", "Player 3", "Player 4"]
        elif val < self.target_number:
            self.result_lbl.config(text=f"Too Low! {val} is not correct.", fg="#f38ba8")
        else:
            self.result_lbl.config(text=f"Too High! {val} is not correct.", fg="#f38ba8")


